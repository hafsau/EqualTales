# EqualTales Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (for Claude models)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenAI API Key (for DALL-E 3 illustrations)
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: Set to "true" to use Goose orchestration
USE_GOOSE=false
